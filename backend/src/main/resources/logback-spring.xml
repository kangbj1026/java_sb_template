<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        [서버 환경별 실행 가이드]
        1. Linux/Unix: java -jar app.jar - -logging.file.path=/home/ubuntu/app/logs
        2. Windows: java -jar app.jar - -logging.file.path=C:\app\logs
        3. Local: 별도 설정 없이 실행 시 기본값인 'backend/logs' 폴더에 생성됨
        application.yml에 정의된 로그 저장 경로를 참조하며, 미설정 시 backend/logs를 기본값으로 사용함
    -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="backend/logs"/>

    <!-- 로그 파일 경로 및 아카이빙 시 사용할 현재 날짜 변수 정의 -->
    <timestamp key="BY_DATE" datePattern="yyyy-MM-dd"/>

    <!-- 콘솔(Console) 출력을 위한 기본 어펜더 설정 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 로그 패턴 설정: 날짜, 스레드명, 레벨, 로거명, 메시지 순으로 출력 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- MDC 값을 기준으로 로그 파일을 동적으로 분류하는 SiftingAppender 설정 -->
    <appender name="SIFT" class="ch.qos.logback.classic.sift.SiftingAppender">
        <!-- logType: 로그의 대분류 (access, errors, serverError 등) -->
        <discriminator>
            <key>logType</key>
            <defaultValue>system</defaultValue> <!-- MDC 값이 없을 경우 'system' 폴더로 분류함 -->
        </discriminator>
        <!-- method: HTTP 메서드 또는 세부 작업명 (GET, POST, SYSTEM 등) -->
        <discriminator>
            <key>method</key>
            <defaultValue>startup</defaultValue> <!-- MDC 값이 없을 경우 'startup' 폴더로 분류함 -->
        </discriminator>

        <sift>
            <!-- 위에서 식별된 logType과 method 변수를 파일 경로에 직접 바인딩함 -->
            <appender name="FILE-${logType}-${method}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <!-- 파일 저장 경로 구성: {기본경로}/{날짜}/{대분류}/{소분류}/api.log -->
                <file>${LOG_PATH}/${BY_DATE}/${logType}/${method}/api.log</file>

                <!-- 로그 파일 관리 정책: 날짜 및 용량 기반 롤링 적용 -->
                <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                    <!-- 로그 유실 방지를 위해 기간 만료 시 압축(.gz) 보관 수행 -->
                    <fileNamePattern>${LOG_PATH}/${BY_DATE}/${logType}/${method}/api.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                    <!-- 개별 로그 파일이 10MB를 초과할 경우 새로운 파일 생성(인덱스 증가) -->
                    <maxFileSize>10MB</maxFileSize>
                    <!-- 최대 30일간 로그 보관 후 자동 삭제 -->
                    <maxHistory>30</maxHistory>
                    <!-- 전체 로그 보관 용량이 2GB를 초과하지 않도록 관리 -->
                    <totalSizeCap>2GB</totalSizeCap>
                </rollingPolicy>

                <encoder>
                    <!-- 파일에 기록될 로그의 포맷 설정 (콘솔과 동일하게 유지) -->
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <!-- 애플리케이션 전체의 로그 레벨 및 출력 방식 지정 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" /> <!-- 표준 출력으로 로그 전송 -->
        <appender-ref ref="SIFT" />    <!-- 파일 분류 시스템으로 로그 전송 -->
    </root>
</configuration>
